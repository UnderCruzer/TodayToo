{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "./dist",
    "paths": {
      "@oneuldo/types": ["../types/index.ts"],
      "@oneuldo/types/*": ["../types/*"],
      "@oneuldo/db": ["../db/index.ts"],
      "@oneuldo/db/*": ["../db/*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
